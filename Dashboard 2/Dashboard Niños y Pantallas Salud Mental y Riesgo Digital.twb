  <worksheets>
    <worksheet name='BN Adolescencia'>
      <table>
        <view>
          <datasources>
            <datasource caption='dataset_limpio_dashboard2' name='federated.1ljcict08f57b611dhsza01mudid' />
          </datasources>
          <datasource-dependencies datasource='federated.1ljcict08f57b611dhsza01mudid'>
            <column caption='Basic Demos-Age' datatype='integer' name='[Basic_Demos-Age]' role='measure' type='quantitative' />
            <column caption='Grupo Edad' datatype='string' name='[Calculation_2004147722633221]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Basic_Demos-Age] &lt;= 9 THEN &quot;0. Infancia (5-9)&quot;&#13;&#10;ELSEIF [Basic_Demos-Age] &lt;= 13 THEN &quot;1. Preadolescencia (10-13)&quot;&#13;&#10;ELSE &quot;2. Adolescencia (14-18)&quot;&#13;&#10;END' />
            </column>
            <column caption='Horas Pantalla Label' datatype='string' name='[Horas_Pantalla_Label]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Alrededor de 1h/día&quot;' value='1. +- 1h/día' />
