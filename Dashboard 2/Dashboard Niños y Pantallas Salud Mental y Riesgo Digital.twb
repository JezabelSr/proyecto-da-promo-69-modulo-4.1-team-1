      <column caption='Basic Demos-Age' datatype='integer' name='[Basic_Demos-Age]' role='measure' type='quantitative' />
      <column caption='Basic Demos-Sex' datatype='integer' name='[Basic_Demos-Sex]' role='measure' type='quantitative' />
      <column caption='CGAS-CGAS Score' datatype='integer' name='[CGAS-CGAS_Score]' role='measure' type='quantitative' />
      <column caption='Donut' datatype='integer' name='[Calculation_0975005456166912]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='2' />
      </column>
      <column caption='Centro' datatype='integer' name='[Calculation_2004147684376579]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Tamaño Burbujas' datatype='real' name='[Calculation_2004147710988292]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='POWER(AVG([PCIAT-PCIAT_Total]), 2)' />
      </column>
      <column caption='Grupo Edad' datatype='string' name='[Calculation_2004147722633221]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Basic_Demos-Age] &lt;= 9 THEN &quot;0. Infancia (5-9)&quot;&#13;&#10;ELSEIF [Basic_Demos-Age] &lt;= 13 THEN &quot;1. Preadolescencia (10-13)&quot;&#13;&#10;ELSE &quot;2. Adolescencia (14-18)&quot;&#13;&#10;END' />
      </column>
      <column caption='Horas Pantalla Label' datatype='string' name='[Horas_Pantalla_Label]' role='dimension' type='nominal'>
