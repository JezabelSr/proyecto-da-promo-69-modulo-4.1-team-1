          <alias key='&quot;Alrededor de 2h/día&quot;' value='2. +- 2h/día' />
          <alias key='&quot;Más de 3h/día&quot;' value='3. &gt; 3h/día' />
          <alias key='&quot;Menos de 1h/día&quot;' value='0. &lt; 1h/día' />
        </aliases>
      </column>
